{
  "name": "mytution",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm run start --workspace apps/mobile",
    "dev:api": "npm run dev --workspace services/api",
    "db:generate": "npm run generate --workspace packages/db",
    "db:push": "npm run push --workspace packages/db",
    "db:migrate": "npm run migrate --workspace packages/db",
    "db:deploy": "npm run deploy --workspace packages/db",
    "db:seed": "npm run seed --workspace packages/db",
    "test:api:smoke": "npm run smoke --workspace services/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
