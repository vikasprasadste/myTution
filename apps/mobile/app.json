{
  "expo": {
    "name": "myTution",
    "slug": "mytution",
    "scheme": "mytution",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/AppIcons/appstore.png",
    "splash": {
      "image": "./assets/splash-screen.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mytution.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mytution.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/AppIcons/playstore.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "98fe900a-48d0-4fbd-b5ed-d211e4c22960"
      }
    },
    "owner": "flipour"
  }
}
