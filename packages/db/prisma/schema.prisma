generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  student
  tutor
  parent
  admin
}

enum ResourceType {
  video
  article
  flashcard
  quiz
}

enum ReminderStatus {
  active
  completed
  cancelled
}

enum ActivityStatus {
  pending
  in_progress
  complete
}

enum BatchRequestStatus {
  pending
  approved
  rejected
  deferred
  suggested
  dismissed
  cancelled
}

enum EnrollmentStatus {
  active
  paused
  completed
}

enum CommunityThreadStatus {
  open
  solved
  archived
}

enum CommunityReactionType {
  upvote
  helpful
  like
}

model User {
  id          String    @id @default(cuid())
  phone       String    @unique
  passwordHash String?
  status      String    @default("active")
  sourceTag   String    @default("app")
  profiles    Profile[]
  userManagementRecords UserManagement[]
  reminders   Reminder[]
  authSessions AuthSession[]
  deviceRegistrations DeviceRegistration[]
  notifications Notification[]
  paymentOrders PaymentOrder[]
  communityThreads CommunityThread[] @relation("CommunityThreadOwner")
  communityComments CommunityComment[] @relation("CommunityCommentOwner")
  communityReactions CommunityReaction[] @relation("CommunityReactionUser")
  communityReports CommunityReport[] @relation("CommunityReportUser")
  parentActivationCodes ParentActivationCode[] @relation("StudentActivationCodes")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, createdAt])
}

model MobileClient {
  id           String        @id @default(cuid())
  clientId     String        @unique
  name         String
  status       String        @default("active")
  sourceTag    String        @default("app")
  authSessions AuthSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AuthSession {
  id                  String       @id @default(cuid())
  userId              String
  mobileClientId      String
  accessToken         String       @unique
  refreshToken        String       @unique
  revokedAt           DateTime?
  accessTokenExpiresAt DateTime
  refreshTokenExpiresAt DateTime
  sourceTag           String       @default("app")
  user                User         @relation(fields: [userId], references: [id])
  mobileClient        MobileClient @relation(fields: [mobileClientId], references: [id])
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([userId, revokedAt])
}

model Profile {
  id                 String             @id @default(cuid())
  userId             String
  role               Role
  firstName          String
  lastName           String
  dob                DateTime?
  city               String?
  communicationAddress String?
  alternatePhone     String?
  avatarUrl          String?
  stream             String?
  specialization     String?
  sourceTag          String             @default("app")
  user               User               @relation(fields: [userId], references: [id])
  reminders          Reminder[]
  deviceRegistrations DeviceRegistration[]
  notifications      Notification[]
  programProgress    ProgramProgress[]
  resourceProgress   ResourceProgress[]
  activityProgress   ActivityProgress[]
  quizAttempts       QuizAttempt[]
  paymentOrders      PaymentOrder[]
  programPurchases   ProgramPurchase[] @relation("StudentProgramPurchases")
  studentProgramSelections StudentProgramSelection[]
  authoredPrograms  Program[]          @relation("ProgramCreator")
  authoredResources Resource[]         @relation("ResourceCreator")
  tutorProfile       TutorProfile?
  studentBatchRequests BatchRequest[] @relation("StudentBatchRequests")
  studentBatchEnrollments BatchEnrollment[] @relation("StudentBatchEnrollments")
  communityThreads CommunityThread[] @relation("CommunityThreadProfile")
  communityComments CommunityComment[] @relation("CommunityCommentProfile")
  communityReports CommunityReport[] @relation("CommunityReportProfile")
  studentParentLinks ParentStudentLink[] @relation("StudentParentLinks")
  parentStudentLinks ParentStudentLink[] @relation("ParentStudentLinks")
  issuedParentActivationCodes ParentActivationCode[] @relation("StudentProfileActivationCodes")
  redeemedParentActivationCodes ParentActivationCode[] @relation("ParentProfileActivationCodes")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([userId, role])
}

model ParentActivationCode {
  id              String    @id @default(cuid())
  code            String    @unique
  studentUserId   String
  studentProfileId String
  parentProfileId String?
  relationship    String
  status          String    @default("active")
  expiresAt       DateTime?
  acceptedAt      DateTime?
  sourceTag       String    @default("app")
  studentUser     User      @relation("StudentActivationCodes", fields: [studentUserId], references: [id], onDelete: Cascade)
  studentProfile  Profile   @relation("StudentProfileActivationCodes", fields: [studentProfileId], references: [id], onDelete: Cascade)
  parentProfile   Profile?  @relation("ParentProfileActivationCodes", fields: [parentProfileId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([studentProfileId, status])
  @@index([code, status])
}

model ParentStudentLink {
  id              String   @id @default(cuid())
  studentProfileId String
  parentProfileId  String
  relationship     String
  status           String   @default("active")
  sourceTag        String   @default("app")
  studentProfile   Profile  @relation("StudentParentLinks", fields: [studentProfileId], references: [id], onDelete: Cascade)
  parentProfile    Profile  @relation("ParentStudentLinks", fields: [parentProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([studentProfileId, parentProfileId])
  @@index([parentProfileId, status])
}

model CommunityThread {
  id             String                @id @default(cuid())
  ownerUserId    String
  ownerProfileId String?
  programId      String?
  batchId        String?
  role           Role
  visibility     String                @default("public")
  title          String
  body           String
  subject        String?
  milestoneTitle String?
  status         CommunityThreadStatus @default(open)
  pinned         Boolean               @default(false)
  anonymous      Boolean               @default(false)
  attachmentUrl  String?
  reportedCount  Int                   @default(0)
  moderatedStatus String               @default("active")
  moderatedReason String?
  sourceTag      String                @default("app")
  ownerUser      User                  @relation("CommunityThreadOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  ownerProfile   Profile?              @relation("CommunityThreadProfile", fields: [ownerProfileId], references: [id], onDelete: SetNull)
  program        Program?              @relation(fields: [programId], references: [id], onDelete: SetNull)
  batch          TutorBatch?           @relation(fields: [batchId], references: [id], onDelete: SetNull)
  comments       CommunityComment[]
  reactions      CommunityReaction[]
  reports        CommunityReport[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([role, status, pinned, createdAt])
  @@index([ownerUserId, createdAt])
  @@index([visibility, programId, batchId])
  @@index([moderatedStatus, reportedCount])
}

model CommunityComment {
  id             String            @id @default(cuid())
  threadId       String
  ownerUserId    String
  ownerProfileId String?
  body           String
  verified       Boolean           @default(false)
  anonymous      Boolean           @default(false)
  sourceTag      String            @default("app")
  thread         CommunityThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  ownerUser      User              @relation("CommunityCommentOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  ownerProfile   Profile?          @relation("CommunityCommentProfile", fields: [ownerProfileId], references: [id], onDelete: SetNull)
  reactions      CommunityReaction[]
  reports        CommunityReport[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([threadId, createdAt])
  @@index([ownerUserId, createdAt])
}

model CommunityReaction {
  id        String                @id @default(cuid())
  userId    String
  threadId  String?
  commentId String?
  type      CommunityReactionType
  sourceTag String                @default("app")
  user      User                  @relation("CommunityReactionUser", fields: [userId], references: [id], onDelete: Cascade)
  thread    CommunityThread?      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  comment   CommunityComment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime              @default(now())

  @@unique([userId, type, threadId])
  @@unique([userId, type, commentId])
  @@index([threadId, type])
  @@index([commentId, type])
  @@index([userId, type])
}

model CommunityReport {
  id             String   @id @default(cuid())
  reporterUserId String
  reporterProfileId String?
  threadId       String?
  commentId      String?
  reason         String
  details        String?
  status         String   @default("open")
  sourceTag      String   @default("app")
  reporterUser   User     @relation("CommunityReportUser", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reporterProfile Profile? @relation("CommunityReportProfile", fields: [reporterProfileId], references: [id], onDelete: SetNull)
  thread         CommunityThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  comment        CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([reporterUserId, threadId, reason])
  @@unique([reporterUserId, commentId, reason])
  @@index([threadId, status])
  @@index([commentId, status])
  @@index([status, createdAt])
}

model UserManagement {
  id                   String   @id @default(cuid())
  userId               String
  role                 Role
  firstName            String
  lastName             String
  dob                  DateTime?
  city                 String?
  communicationAddress String?
  alternatePhone       String?
  avatarUrl            String?
  stream               String?
  specialization       String?
  sourceTag            String   @default("app")
  user                 User     @relation(fields: [userId], references: [id])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([userId, role])
  @@index([role, city])
}

model TutorProfile {
  id              String       @id @default(cuid())
  profileId       String       @unique
  headline        String
  subjects        String
  boards          String
  grades          String
  languages       String
  mode            String
  experienceYears Int
  rating          Float
  hourlyRate      Int
  gender          String
  location        String
  bio             String
  verificationStatus String    @default("unverified")
  profileStatus   String       @default("active")
  sourceTag       String       @default("app")
  profile         Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  batches         TutorBatch[]
  accountingEntries TutorAccountingEntry[]
  paymentOrders   PaymentOrder[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([location, gender])
  @@index([rating, experienceYears])
  @@index([verificationStatus, profileStatus, updatedAt])
}

model TutorBatch {
  id                String            @id @default(cuid())
  tutorProfileId    String
  programId         String?
  title             String
  course            String
  subject           String
  grade             String
  board             String
  mode              String
  schedule          String
  classroomLocation String?
  onlineLink        String?
  startsAt          DateTime
  capacity          Int               @default(12)
  status            String            @default("available")
  feeType           String            @default("free")
  feeAmount         Int?
  sourceTag         String            @default("app")
  tutorProfile      TutorProfile      @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)
  program           Program?          @relation(fields: [programId], references: [id], onDelete: SetNull)
  requests          BatchRequest[]
  enrollments       BatchEnrollment[]
  communityThreads  CommunityThread[]
  paymentOrders     PaymentOrder[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([subject, grade, board, mode])
  @@index([tutorProfileId, status])
  @@index([programId, status])
  @@index([status, startsAt])
  @@index([startsAt])
}

model BatchRequest {
  id               String             @id @default(cuid())
  batchId          String
  suggestedBatchId String?
  studentProfileId String
  paymentOrderId   String?            @unique
  status           BatchRequestStatus @default(pending)
  message          String?
  tutorResponse    String?
  sourceTag        String             @default("app")
  batch            TutorBatch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  studentProfile   Profile            @relation("StudentBatchRequests", fields: [studentProfileId], references: [id], onDelete: Cascade)
  paymentOrder     PaymentOrder?      @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)
  enrollment       BatchEnrollment?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([batchId, studentProfileId])
  @@index([studentProfileId, status])
  @@index([batchId, status])
}

model BatchEnrollment {
  id               String           @id @default(cuid())
  batchId          String
  studentProfileId String
  requestId        String?          @unique
  status           EnrollmentStatus @default(active)
  sourceTag        String           @default("app")
  batch            TutorBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  studentProfile   Profile          @relation("StudentBatchEnrollments", fields: [studentProfileId], references: [id], onDelete: Cascade)
  request          BatchRequest?    @relation(fields: [requestId], references: [id], onDelete: SetNull)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([batchId, studentProfileId])
  @@index([studentProfileId, status])
}

model Recommendation {
  id             String       @id @default(cuid())
  role           Role
  type           ResourceType
  title          String
  description    String
  thumbnailLabel String
  content        Resource?    @relation(fields: [resourceId], references: [id])
  resourceId     String?
  sourceTag      String       @default("app")
  createdAt      DateTime     @default(now())
}

model Resource {
  id               String             @id @default(cuid())
  creatorProfileId String?
  type             ResourceType
  title            String
  description      String
  body             String?
  assetSlug        String?            @unique
  assetProvider    String             @default("repo")
  accessLevel      String             @default("program")
  assetVersion     String             @default("v1")
  storageType      String             @default("db")
  contentJson      Json?
  thumbnailPath    String?
  bannerPath       String?
  vttPath          String?
  metadataPath     String?
  sourceUrl        String?
  recommendations  Recommendation[]
  flashcards       Flashcard[]
  milestoneActivities MilestoneActivity[]
  progress         ResourceProgress[]
  quizAttempts     QuizAttempt[]
  creatorProfile   Profile?           @relation("ResourceCreator", fields: [creatorProfileId], references: [id], onDelete: SetNull)
  sourceTag        String             @default("app")
  createdAt        DateTime           @default(now())

  @@index([creatorProfileId, type])
}

model Flashcard {
  id               String   @id @default(cuid())
  resourceId        String
  sequence          Int
  question          String
  answer            String
  relatedArticleId  String?
  sourceTag         String   @default("app")
  resource          Resource @relation(fields: [resourceId], references: [id])
}

model Reminder {
  id        String         @id @default(cuid())
  userId    String
  profileId String
  role      Role
  title     String
  startsAt  DateTime
  status    ReminderStatus @default(active)
  sourceTag String         @default("app")
  user      User           @relation(fields: [userId], references: [id])
  profile   Profile        @relation(fields: [profileId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([profileId, startsAt, status])
}

model DeviceRegistration {
  id        String   @id @default(cuid())
  userId    String
  profileId String?
  role      Role
  platform  String
  pushToken String   @unique
  deviceId  String?
  provider  String   @default("expo")
  status    String   @default("active")
  sourceTag String   @default("app")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([profileId, status])
  @@index([role, status])
}

model Notification {
  id                String    @id @default(cuid())
  userId            String
  profileId         String?
  role              Role
  type              String
  title             String
  body              String
  data              Json?
  channel           String    @default("in_app")
  provider          String    @default("internal")
  providerMessageId String?
  status            String    @default("sent")
  priority          String    @default("normal")
  scheduledAt       DateTime?
  sentAt            DateTime?
  readAt            DateTime?
  sourceTag         String    @default("app")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile           Profile?  @relation(fields: [profileId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId, status, createdAt])
  @@index([profileId, status, createdAt])
  @@index([scheduledAt, status])
  @@index([type, createdAt])
}

model Program {
  id          String             @id @default(cuid())
  creatorProfileId String?
  role        Role
  title       String
  description String
  visibility  String             @default("private")
  status      String             @default("draft")
  feeType     String             @default("free")
  feeAmount   Int?
  sourceTag   String             @default("app")
  creatorProfile Profile?         @relation("ProgramCreator", fields: [creatorProfileId], references: [id], onDelete: SetNull)
  batches     TutorBatch[]
  milestones  ProgramMilestone[]
  progress    ProgramProgress[]
  studentSelections StudentProgramSelection[]
  communityThreads CommunityThread[]
  paymentOrders PaymentOrder[]
  purchases ProgramPurchase[]

  @@index([creatorProfileId, status])
  @@index([role, status, visibility])
  @@index([status, visibility])
}

model PaymentOrder {
  id               String   @id @default(cuid())
  userId           String
  profileId        String
  role             Role
  targetType       String
  targetId         String
  programId        String?
  batchId          String?
  batchRequestId   String?
  tutorProfileId   String?
  amount           Int
  currency         String   @default("INR")
  status           String   @default("requires_payment")
  gatewayProvider  String   @default("mock")
  gatewayOrderId   String   @unique
  gatewayPaymentId String?
  methodType       String?
  paymentRail      String?
  metadata         Json?
  refundStatus     String   @default("none")
  cancelReason     String?
  paidAt           DateTime?
  cancelledAt      DateTime?
  refundedAt       DateTime?
  sourceTag        String   @default("app")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile          Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  program          Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  batch            TutorBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  batchRequest     BatchRequest?
  tutorProfile     TutorProfile? @relation(fields: [tutorProfileId], references: [id], onDelete: SetNull)
  programPurchase  ProgramPurchase?
  accountingEntries TutorAccountingEntry[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([profileId, status, createdAt])
  @@index([targetType, targetId])
  @@index([tutorProfileId, status])
  @@index([status, createdAt])
}

model ProgramPurchase {
  id               String   @id @default(cuid())
  orderId          String   @unique
  programId        String
  studentProfileId String
  status           String   @default("pending")
  accessStatus     String   @default("locked")
  purchasedAt      DateTime?
  cancelledAt      DateTime?
  refundedAt       DateTime?
  sourceTag        String   @default("app")
  order            PaymentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  program          Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  studentProfile   Profile @relation("StudentProgramPurchases", fields: [studentProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([programId, studentProfileId])
  @@index([studentProfileId, status])
}

model TutorAccountingEntry {
  id               String   @id @default(cuid())
  tutorProfileId   String
  paymentOrderId   String?
  sourceType       String
  sourceId         String
  grossAmount      Int
  platformFee      Int
  netAmount        Int
  currency         String   @default("INR")
  status           String   @default("pending")
  payoutReference  String?
  sourceTag        String   @default("app")
  tutorProfile     TutorProfile @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)
  paymentOrder     PaymentOrder? @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tutorProfileId, status])
  @@index([paymentOrderId])
}

model StudentProgramSelection {
  id        String   @id @default(cuid())
  profileId String
  programId String
  status    String   @default("active")
  sourceTag String   @default("app")
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, programId])
  @@index([profileId, status])
  @@index([programId, status])
}

model ProgramMilestone {
  id        String   @id @default(cuid())
  programId String
  sequence  Int
  title     String
  sourceTag String   @default("app")
  program   Program  @relation(fields: [programId], references: [id])
  activities MilestoneActivity[]

  @@unique([programId, sequence])
}

model MilestoneActivity {
  id          String         @id @default(cuid())
  milestoneId String
  resourceId  String
  sequence    Int
  type        ResourceType
  title       String
  description String
  sourceTag   String         @default("app")
  progress    ActivityProgress[]
  milestone   ProgramMilestone @relation(fields: [milestoneId], references: [id])
  resource    Resource       @relation(fields: [resourceId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([milestoneId, sequence])
}

model ProgramProgress {
  id                         String   @id @default(cuid())
  profileId                  String
  programId                  String
  unlockedMilestoneSequence  Int      @default(1)
  completedMilestoneSequence Int      @default(0)
  sourceTag                  String   @default("app")
  profile                    Profile  @relation(fields: [profileId], references: [id])
  program                    Program  @relation(fields: [programId], references: [id])

  @@unique([profileId, programId])
}

model ResourceProgress {
  id          String    @id @default(cuid())
  profileId   String
  resourceId  String
  status      String    @default("started")
  completedAt DateTime?
  sourceTag   String    @default("app")
  profile     Profile   @relation(fields: [profileId], references: [id])
  resource    Resource  @relation(fields: [resourceId], references: [id])

  @@unique([profileId, resourceId])
}

model ActivityProgress {
  id          String         @id @default(cuid())
  profileId   String
  activityId  String
  status      ActivityStatus @default(in_progress)
  completedAt DateTime?
  sourceTag   String         @default("app")
  profile     Profile        @relation(fields: [profileId], references: [id])
  activity    MilestoneActivity @relation(fields: [activityId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([profileId, activityId])
  @@index([profileId, status])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  profileId   String
  resourceId  String
  score       Int
  total       Int
  percent     Int
  answers     Json
  sourceTag   String   @default("app")
  profile     Profile  @relation(fields: [profileId], references: [id])
  resource    Resource @relation(fields: [resourceId], references: [id])
  createdAt   DateTime @default(now())

  @@index([profileId, resourceId, createdAt])
  @@index([resourceId, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  profileId   String?
  role        Role?
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  sourceTag   String   @default("app")
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([profileId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId, createdAt])
}

model AdminReview {
  id             String   @id @default(cuid())
  entityType     String
  entityId       String
  reviewType     String
  status         String   @default("pending")
  priority       String   @default("normal")
  assignedTo     String?
  decision       String?
  reason         String?
  metadata       Json?
  sourceTag      String   @default("app")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  decidedAt      DateTime?

  @@unique([entityType, entityId, reviewType])
  @@index([status, reviewType, createdAt])
  @@index([entityType, entityId])
}

model AdminConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  scope       String   @default("global")
  value       Json
  status      String   @default("active")
  updatedBy   String?
  sourceTag   String   @default("app")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope, status])
}
